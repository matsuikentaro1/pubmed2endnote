{
  "manifest_version": 3,
  "name": "PubMed2EndNote",
  "version": "3.0",
  "description": "Copy PubMed citations to clipboard as EndNote-compatible Word citations with one click",
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": ["https://pubmed.ncbi.nlm.nih.gov/*"],
      "js": ["citation.js", "content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "PubMed2EndNote"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://pubmed.ncbi.nlm.nih.gov/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
